# Database Configuration
DATABASE_URL=file:./data/sync.db

# Encryption Key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate-random-32-byte-hex-key-here

# iCloud Settings (legacy - will be moved to database)
ICLOUD_USERNAME=your-icloud-email@icloud.com
ICLOUD_PASSWORD=your-app-specific-password
ICLOUD_SOURCE_ALBUM=Frame Sync

# Samsung Frame TV Settings (legacy - will be moved to database)
SAMSUNG_FRAME_HOST=192.168.1.100

# Optional Settings
ICLOUD_SYNC_INTERVAL=60
LOG_LEVEL=info
WEB_PORT=3000
CORS_ORIGIN=http://localhost:5173