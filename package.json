{
	"name": "nodejs-typescript-template",
	"version": "1.470.0",
	"description": "A template for a nodejs application, using typescript",
	"main": "dist/app.js",
	"author": "",
	"license": "MIT",
	"module": "dist/app.js",
	"type": "module",
	"bin": {
		"icloud-frame-sync": "./bin/icloud-frame-sync.js"
	},
	"scripts": {
		"dev": "tsx ./src/app.ts",
		"dev:web": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
		"dev:server": "tsx ./src/web-app.ts",
		"dev:client": "vite",
		"build": "npm run build:server && npm run build:client",
		"build:server": "tsc",
		"build:client": "vite build",
		"start": "node ./dist/app.js",
		"start:web": "node ./dist/web-app.js",
		"start:deno": "deno run --allow-read --allow-write --allow-net --allow-env --allow-sys --allow-run --unstable --watch src/app.ts",
		"lint": "eslint --fix --quiet src/**/*.ts",
		"format": "prettier --loglevel silent --write src/**/*.ts",
		"test": "mocha --require tsx/cjs --recursive 'test/**/*.test.ts'",
		"test:watch": "mocha --require tsx/cjs --recursive 'test/**/*.test.ts' --watch",
		"test:coverage": "nyc mocha --require tsx/cjs --recursive 'test/**/*.test.ts'",
		"test:unit": "mocha --require tsx/cjs --recursive 'test/unit/**/*.test.ts'",
		"test:integration": "mocha --require tsx/cjs --recursive 'test/integration/**/*.test.ts'",
		"test:web": "vitest run"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "1.51.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@hookform/resolvers": "^5.2.2",
		"@mui/icons-material": "^7.3.4",
		"@mui/lab": "7.0.1-beta.18",
		"@mui/material": "^7.3.4",
		"@prisma/client": "^6.19.0",
		"@tanstack/react-query": "^5.99.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.0",
		"commander": "^14.0.2",
		"concurrently": "^9.2.1",
		"cors": "^2.8.5",
		"exif": "^0.6.0",
		"exif-parser": "^0.1.12",
		"exif-reader": "^2.0.2",
		"express": "^5.1.0",
		"icloudjs": "1.6.2",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.2",
		"prisma": "^6.19.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.72.1",
		"react-router-dom": "^7.14.1",
		"react-window": "^2.2.7",
		"samsung-frame-connect": "github:pradeepmouli/samsung-frame-connect#add-getThumbnail-method",
		"sharp": "^0.34.4",
		"vite": "^7.1.10",
		"zod": "^4.1.12",
		"zod-express-middleware": "^1.4.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"@testing-library/jest-dom": "^6.4.6",
		"@testing-library/react": "^14.1.2",
		"@testing-library/user-event": "^14.5.1",
		"@types/chai": "^5.2.2",
		"@types/exif": "^0.6.5",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.8.1",
		"@types/node-fetch": "^2.6.12",
		"@types/sharp": "^0.32.0",
		"@types/sinon": "^17.0.4",
		"@types/supertest": "^2.0.16",
		"@types/tough-cookie": "^4.0.5",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"chai": "^6.2.0",
		"deno": "^2.5.4",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"globals": "^16.4.0",
		"jiti": "^2.6.1",
		"jsdom": "^24.1.0",
		"mocha": "^11.7.4",
		"nodemon": "^3.1.10",
		"nyc": "^17.1.0",
		"prettier": "^3.8.3",
		"sinon": "^21.0.0",
		"supertest": "^7.0.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.6",
		"type-fest": "^5.1.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"typescript-eslint-parser": "^22.0.0",
		"vitest": "^2.1.3"
	}
}